# =================================================================
# Robert Castellino site — environment variables
#
# Copy to .env.local for local dev, or set in the Vercel dashboard
# for production. Until DATABASE_URL is set, the public site reads
# from the static data files in src/data/ — nothing breaks.
# =================================================================

# Postgres connection (Vercel Postgres → "Connection String" tab).
# Required for: admin, contact submissions, DB-backed musings/photos.
DATABASE_URL=

# Admin login — used by /admin/login. Hash the password with bcrypt
# (cost 10). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 'your-password'
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Random secret used to sign the admin session JWT. 32+ chars.
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=

# Resend API key — used to email contact-form submissions to the studio.
# https://resend.com → API Keys
RESEND_API_KEY=

# Where contact submissions are mailed.
CONTACT_TO_EMAIL=rlcatellino@gmail.com

# "From" address used by Resend. Must be on a verified domain in Resend.
# Until a domain is verified, you can use the Resend sandbox sender.
CONTACT_FROM_EMAIL=studio@robertcastellino.com

# Vercel Blob — for admin photo uploads. Created automatically when you
# enable Blob in the Vercel dashboard for this project.
BLOB_READ_WRITE_TOKEN=

# Stripe — print & book checkout. Until STRIPE_SECRET_KEY is set, the
# "Purchase with Stripe" buttons return "checkout not set up yet" cleanly.
# Get keys at https://dashboard.stripe.com/apikeys
#   • TEST keys (sk_test_…) first — fake cards, no real money.
#   • LIVE keys (sk_live_…) only when you're ready to take real payments.
STRIPE_SECRET_KEY=

# Optional. Absolute base URL used to build Stripe success/cancel return
# links. Leave blank for local dev (it's inferred from the request);
# set to https://robertcastellino.com in production.
NEXT_PUBLIC_SITE_URL=
